# Nano Claude Code — API Configuration
# Copy this file to .env and fill in your keys.
# Priority: .env > shell environment > ~/.nano_claude/config.json
#
# If OPENAI_COMPAT_BASE_URL and OPENAI_COMPAT_API_KEY are both set (non-empty),
# OpenAI-compat is used and takes priority over Anthropic / OpenRouter.

# ── OpenAI-compatible: Azure OpenAI / AI Foundry (replace host with yours) ──
# OPENAI_COMPAT_BASE_URL=https://YOUR_RESOURCE.services.ai.azure.com/openai/v1/
# OPENAI_COMPAT_API_KEY=your-azure-api-key
# OPENAI_COMPAT_MODEL=FW-MiniMax-M2.5

# ── OpenAI-compatible: another Azure / proxy endpoint ──
# OPENAI_COMPAT_BASE_URL=https://YOUR_RESOURCE.services.ai.azure.com/openai/v1/
# OPENAI_COMPAT_API_KEY=your-azure-api-key
# OPENAI_COMPAT_MODEL=Kimi-K2.5

# ── Direct Anthropic (sk-ant-* prefix) ──
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenRouter ──
# OPENROUTER_API_KEY=sk-or-xxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── Generic Anthropic-compatible proxy ──
# ANTHROPIC_API_KEY=your-proxy-key
# ANTHROPIC_BASE_URL=https://your-proxy.com
